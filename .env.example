# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sonic_atlas"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Last.fm API (required)
LASTFM_API_KEY="your-lastfm-api-key"

# Discogs API (optional — enriches genre/style data)
DISCOGS_CONSUMER_KEY="your-discogs-consumer-key"
DISCOGS_CONSUMER_SECRET="your-discogs-consumer-secret"

# Ticketmaster API (optional — concert/event data)
TICKETMASTER_API_KEY="your-ticketmaster-api-key"
