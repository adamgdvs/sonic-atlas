generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bookmarks     BookmarkedArtist[]
  votes         ArtistVote[]
  playlists     Playlist[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom model for Sonic Atlas
model BookmarkedArtist {
  id        String   @id @default(cuid())
  userId    String
  artistId  String   // Use artist name as ID for simplicity since it's unique in Last.fm
  name      String
  imageUrl  String?
  genres    String   // Store as JSON stringified array of strings
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only bookmark an artist once
  @@unique([userId, artistId])
}

// Persistent API response cache
model ApiCache {
  key       String   @id          // e.g. "lastfm:tags:radiohead"
  data      String   @db.Text     // JSON stringified response
  expiresAt DateTime              // When this entry should be considered stale
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// Global artist voting (thumbs up / thumbs down)
model ArtistVote {
  id        String   @id @default(cuid())
  userId    String
  artistId  String   // normalized lowercase artist name
  vote      Int      // +1 (thumbs up) or -1 (thumbs down)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
  @@index([artistId])
}

// User playlists
model Playlist {
  id          String          @id @default(cuid())
  userId      String
  name        String
  description String?
  coverUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks      PlaylistTrack[]

  @@index([userId])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  title      String
  artist     String
  url        String   // preview URL or empty for YT-only
  videoId    String?  // YouTube video ID for full playback
  coverUrl   String?
  genres     String   @default("[]") // JSON array
  position   Int      // ordering within playlist
  addedAt    DateTime @default(now())

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@unique([playlistId, position])
}

// Imported public playlists sourced from external catalogs like Deezer
model ImportedPlaylist {
  id               String                @id @default(cuid())
  source           String
  sourcePlaylistId String
  title            String
  description      String?
  creator          String?
  coverUrl         String?
  sourceUrl        String?
  checksum         String?
  trackCount       Int?
  matchedCoverage  Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tracks           ImportedPlaylistTrack[]

  @@unique([source, sourcePlaylistId])
  @@index([source, sourcePlaylistId])
  @@index([title])
}

model ImportedPlaylistTrack {
  id                 String           @id @default(cuid())
  importedPlaylistId String
  sourceTrackId      String
  title              String
  artist             String
  album              String?
  duration           Int?
  explicit           Boolean          @default(false)
  previewUrl         String?
  sourceUrl          String?
  coverUrl           String?
  isrc               String?
  position           Int
  matchStatus        String
  matchConfidence    Float?
  videoId            String?
  matchedTitle       String?
  matchedArtist      String?
  matchedThumbnailUrl String?
  createdAt          DateTime         @default(now())

  importedPlaylist   ImportedPlaylist @relation(fields: [importedPlaylistId], references: [id], onDelete: Cascade)

  @@index([importedPlaylistId])
  @@index([videoId])
  @@index([artist])
  @@unique([importedPlaylistId, position])
}

// Global scan event tracking for Frequency Hub
model ScanEvent {
  id         String   @id @default(cuid())
  artistName String
  userId     String?  // nullable for anonymous visitors
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([artistName])
}
